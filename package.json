{
  "name": "ludus-ux",
  "version": "1.1.2",
  "description": "Open-source web UI for the Ludus cyber range platform",
  "license": "Apache-2.0",
  "scripts": {
    "copy:monaco": "node scripts/copy-monaco.js",
    "dev": "npm run copy:monaco && next dev --webpack",
    "build": "npm run copy:monaco && next build --webpack",
    "start": "next start -p 3000",
    "lint": "eslint .",
    "lint:types": "tsc --noEmit",
    "postinstall": "npm rebuild better-sqlite3 || true",
    "test:unit": "vitest run -c config/vitest.config.ts",
    "test:e2e": "playwright test -c config/playwright.config.ts",
    "test:perf": "playwright test -c config/playwright.config.ts e2e/perf-refresh.spec.ts"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tanstack/react-query": "^5.90.21",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "js-yaml": "^4.2.0",
    "lucide-react": "^0.400.0",
    "monaco-editor": "^0.46.0",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^2.1.7",
    "recharts": "^2.12.7",
    "ssh2": "^1.15.0",
    "tar": "^7.5.11",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "ws": "^8.21.0"
  },
  "overrides": {
    "rimraf": "^5.0.10",
    "dompurify": ">=3.3.2",
    "cross-spawn": ">=7.0.5",
    "glob": ">=10.5.0",
    "@eslint/config-array": {
      "minimatch": {
        "brace-expansion": "1.1.13"
      }
    },
    "next": {
      "postcss": "8.5.10"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ssh2": "^1.11.19",
    "@types/tar": "^6.1.13",
    "@types/ws": "^8.5.13",
    "autoprefixer": "^10.0.1",
    "eslint": "^9.21.0",
    "eslint-config-next": "^16.2.7",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.3.0",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
