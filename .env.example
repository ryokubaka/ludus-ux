# ─────────────────────────────────────────────────────────────────
# Ludus UX Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────

# ── Authentication ──────────────────────────────────────────────
# Hostname or IP of your Ludus server (used for SSH login + GOAD commands).
LUDUS_SSH_HOST=192.168.0.100
LUDUS_SSH_PORT=22

# If LUDUS_SSH_HOST is a hostname that Docker cannot resolve
# — because it's only in your Windows/Mac hosts file, behind a VPN DNS, or a local
# lab name — set LUDUS_SERVER_IP to the server's IP address.  The container will
# automatically inject the hostname→IP mapping into /etc/hosts at startup so SSH,
# HTTP, and TLS all work correctly without any other changes.

# LUDUS_SERVER_IP=192.168.1.100

# Secret used to encrypt session cookies. Generate a random string:
#   openssl rand -hex 32
APP_SECRET=change-me-to-a-random-secret-string-32-chars

# ── Ludus API ────────────────────────────────────────────────────
# LUDUS_URL and LUDUS_ADMIN_URL are derived automatically from LUDUS_SSH_HOST
# in docker-compose.yml (https://<host>:8080 and https://<host>:8081).
# Only set these if you need to override the defaults.
# LUDUS_URL=https://${LUDUS_SSH_HOST}:8080
# LUDUS_ADMIN_URL=https://${LUDUS_SSH_HOST}:8081

# ROOT API key — required for admin operations in Ludus v2 (user create/delete).
# Found at: /opt/ludus/install/root-api-key on the Ludus server.
LUDUS_ROOT_API_KEY=

# Proxmox/root SSH credentials — required for VM console (SPICE) access AND GOAD commands.
# The Ludus server IS the Proxmox host. Must be a user with root/sudo access (default: root).
PROXMOX_SSH_USER=root
PROXMOX_SSH_PASSWORD=

# Set to 'true' only if Ludus has a valid CA-signed TLS cert.
# Leave false for the default self-signed certificate.
LUDUS_VERIFY_TLS=false

# ── TLS / HTTPS ──────────────────────────────────────────────────
# The app serves HTTPS on port 3000 (mapped to 443 on the host).
# Place your own cert + key in the certificates/ directory, or leave these
# at their defaults and the container will auto-generate a self-signed cert
# on first startup. Generated certs persist in the certificates/ volume.
#
# TLS_CERT_PATH=/app/certificates/cert.pem
# TLS_KEY_PATH=/app/certificates/key.pem
#
# Optional: hostname or IP used to access this app from your browser.
# This is added to the cert's Subject Alternative Name so the browser
# doesn't show a "Your connection is not private" warning.
# The Docker host's LAN IP is included automatically; only set this if you
# access the app via a custom DNS name (e.g. ludus-ui.lab.local).
# Defaults to LUDUS_SSH_HOST if unset.
# TLS_HOSTNAME=ludus-ui.lab.local


# ── GOAD Integration ─────────────────────────────────────────────
# Path to GOAD on the Ludus server (default: /opt/GOAD)
GOAD_PATH=/opt/GOAD

# GOAD uses the same SSH host as LUDUS_SSH_HOST above — no separate host needed.
# It also uses the root SSH credentials below (PROXMOX_SSH_USER / PROXMOX_SSH_PASSWORD).
#
# Optional: override the SSH key path for GOAD (Docker volume mount).
# Place your private key at ./ssh/id_rsa on the host; it mounts to /app/ssh/id_rsa.
# Only needed if you prefer key-based auth over password auth.
# GOAD_SSH_KEY_PATH=/app/ssh/id_rsa
