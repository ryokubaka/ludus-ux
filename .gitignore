# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js
.next/
out/

# Environment
.env
.env.local
.env.production

# Build
dist/

# TypeScript incremental at repo root (real cache lives under .next/cache per tsconfig)
/tsconfig.tsbuildinfo

# Secrets (keep the directory but not the keys)
ssh/*.pem
ssh/*.key
ssh/id_*
ssh/*.p12
!ssh/.gitkeep

# TLS certificates for nginx edge (keep the directory but not the cert files)
docker/nginx/certificates/*.pem
docker/nginx/certificates/*.key
docker/nginx/certificates/*.crt
docker/nginx/certificates/*.p12
!docker/nginx/certificates/.gitkeep

# Persistent data (SQLite DB — volume-mounted at runtime, not committed to git)
data/

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# E2E
e2e/FINDINGS.md

# OS
.DS_Store
Thumbs.db

# Generated at build time: Monaco Editor VS files copied from node_modules
/public/monaco-vs

# Developer docs (internal notes, not for end users)
docs/CURRENT_STATUS.md

# Local sync scripts
sync-to-git.sh
sync-to-git.ps1