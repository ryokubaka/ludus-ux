# ─────────────────────────────────────────────────────────────────
# Ludus UX — copy to .env and fill in your values. See README Quick Start.
# ─────────────────────────────────────────────────────────────────

# ── Authentication ──────────────────────────────────────────────
# Ludus server hostname or IP (SSH login, GOAD, and compose builds LUDUS_* URLs from this).
LUDUS_SSH_HOST=192.168.0.100
LUDUS_SSH_PORT=22

# If the hostname only resolves on the Docker host (VPN, hosts file, lab DNS), set the IP.
# The container adds hostname→IP to /etc/hosts at startup.
# LUDUS_SERVER_IP=192.168.1.100

# Session cookies — use a long random value (e.g. openssl rand -hex 32)
APP_SECRET=change-me-to-a-random-secret-string-32-chars

# ── Ludus API ────────────────────────────────────────────────────
# docker-compose sets these from LUDUS_SSH_HOST unless you define overrides here.
# Uncomment to force explicit URLs (otherwise compose defaults apply at `docker compose up`).
# LUDUS_URL=https://${LUDUS_SSH_HOST}:8080
# LUDUS_ADMIN_URL=https://${LUDUS_SSH_HOST}:8081

# Required for Ludus v2 admin features (users, ranges, etc.). On server: /opt/ludus/install/root-api-key
LUDUS_ROOT_API_KEY=

# Proxmox / root SSH — Ludus runs on the Proxmox host. Prefer a private key from the server
# in SSH_KEY_PATH (default ./ssh → /app/ssh); leave PROXMOX_SSH_PASSWORD empty when using a key.
# README: copy key from Ludus server, chmod 755 on the ssh directory on Linux, authorized_keys.
PROXMOX_SSH_USER=root
PROXMOX_SSH_PASSWORD=
# Path inside the container (matches ./ssh/id_rsa on the host by default)
PROXMOX_SSH_KEY_PATH=/app/ssh/id_rsa
# PROXMOX_SSH_KEY_PASSPHRASE=

# true only if Ludus uses a CA-trusted TLS cert; false for default self-signed
LUDUS_VERIFY_TLS=false

# ── TLS / HTTPS (LUX app) ────────────────────────────────────────
# DISABLE_HTTPS=true — plain HTTP on port 3000 (useful for local browser testing)
DISABLE_HTTPS=false
# Custom certs in ./certificates/ — optional; container can auto-generate if unset
# TLS_CERT_PATH=/app/certificates/cert.pem
# TLS_KEY_PATH=/app/certificates/key.pem
# CN/SAN for auto-generated cert; defaults to LUDUS_SSH_HOST if unset
# TLS_HOSTNAME=

# ── GOAD ─────────────────────────────────────────────────────────
# false hides GOAD in the UI (can also toggle in Settings while running)
ENABLE_GOAD=true
# Path to GOAD on the Ludus server (must match the server layout)
GOAD_PATH=/opt/GOAD
# Optional; same key as PROXMOX_SSH_KEY_PATH unless you need a separate file
# GOAD_SSH_KEY_PATH=/app/ssh/id_rsa

# ── Docker Compose volumes (host paths) ────────────────────────
# Directory on the LUX host holding the root private key copied from the Ludus server
SSH_KEY_PATH=./ssh
# SQLite, uploads, task logs
# DATA_DIR=./data
